# ─── 전자소송(ecfs) 로그인 ────────────────────────────────
# 전자소송 사이트(ecfs.scourt.go.kr) 사용자 ID
ECFS_USER_ID=your_ecfs_id

# 공동인증서 비밀번호.
# 권장: setup_env.ps1 로 입력하면 Windows DPAPI 로 암호화되어 ECFS_CERT_PW_ENC 로 저장됩니다(평문 저장 안 함).
# 평문으로 직접 넣으려면 아래 줄 사용(보안상 비권장):
ECFS_CERT_PW=your_certificate_password
# ECFS_CERT_PW_ENC=<DPAPI 암호문(base64) — setup_env.ps1 이 자동 생성>

# 인증서 목록에서 선택할 이름 (보통 본인 성명 또는 법인명).
# 하드디스크에 저장된 인증서 목록에서 이 문자열이 포함된 항목을 선택합니다.
ECFS_CERT_NAME=홍길동

# 인증서 저장 위치 탭. 전자소송 공동인증서 로그인 창의 저장매체 선택 값과 동일하게.
# 가능한 값(전자소송 UI 라벨 그대로): 브라우저 / 인증서찾기 / 하드디스크 / 이동식디스크 / 스마트인증
ECFS_CERT_STORAGE=하드디스크

# (자동 폴백) 브라우저 탭에 인증서가 없을 때 '인증서찾기'로 자동 등록하기 위한 NPKI 위치.
# 둘 중 하나만 지정. ECFS_CERT_STORAGE=브라우저 일 때 권장.
# ECFS_CERT_DIR=C:/Users/<USER>/AppData/LocalLow/NPKI/yessign/USER/cn=...
# ECFS_CERT_SERIAL=<인증서 시리얼 일부 (NPKI 폴더명에 포함된 숫자)>

# ─── 사건 폴더 ────────────────────────────────────────────
# 다운로드한 사건기록(법원명_사건번호 폴더)을 저장할 루트 디렉토리.
# 클라우드 동기화 폴더(OneDrive/Google Drive/Dropbox 등)를 지정하면
# 데스크톱 클라이언트가 자동으로 클라우드에 업로드합니다.
ECOURT_CASES_DIR=D:/CloudSync/진행중사건

# (선택) pdf_to_md.py 의 MD 출력 디렉토리
# ECOURT_MD_OUTPUT=./md_output

# ─── 텔레그램 알림 ────────────────────────────────────────
# @BotFather 에서 발급받은 봇 토큰. setup_env.ps1 사용 시 DPAPI 암호화(TELEGRAM_BOT_TOKEN_ENC).
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 알림을 받을 채팅 ID (본인 계정 또는 그룹).
# 봇에게 메시지를 보낸 뒤 https://api.telegram.org/bot<TOKEN>/getUpdates 로 확인.
TELEGRAM_CHAT_ID=123456789

# ─── 데몬 스케줄 ──────────────────────────────────────────
# daily_sync_daemon.py 가 매일 실행할 시각 (24h, HH:MM)
SYNC_TIME=18:03
